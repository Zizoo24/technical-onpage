# ── Server ────────────────────────────────────────────────────────
# Port the container listens on (Dublyo / hosting platform sets this)
PORT=3000

# Node environment
NODE_ENV=production

# ── Database (Prisma) ─────────────────────────────────────────────
DATABASE_URL=postgresql://news-seo-db:<password>@news-seo-db-<id>.dublyo.co:5432/platform?sslmode=require

# ── Frontend (Vite build-time only) ──────────────────────────────
# Leave empty for same-origin (recommended for Docker deployment).
# Set to a full URL only if the API is hosted separately.
VITE_API_BASE_URL=
