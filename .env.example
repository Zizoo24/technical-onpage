# ── Server ────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Database (Optional — Supabase) ───────────────────────────────
# Leave blank to run in in-memory mode (no database needed).
# Set both to enable persistent audit storage via Supabase.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Legacy aliases (also accepted):
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# ── Frontend (Vite build-time only) ──────────────────────────────
# Leave empty for same-origin (recommended for Docker deployment).
# Set to a full URL only if the API is hosted separately.
VITE_API_BASE_URL=

# ── Optional: PageSpeed Insights API key ─────────────────────────
# If set, performance checks will include PSI data.
# PAGESPEED_API_KEY=
